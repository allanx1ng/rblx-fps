{
  "name": "fps-game-test",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      },
      "Remotes": {
        "$className": "Folder",
        "DealDamage": { "$className": "RemoteEvent" },
        "FireProjectile": { "$className": "RemoteEvent" },
        "ProjectileSpawned": { "$className": "RemoteEvent" },
        "UseHealingPotion": { "$className": "RemoteEvent" },
        "EquipWeapon": { "$className": "RemoteEvent" },
        "SelectSlot": { "$className": "RemoteEvent" },
        "PurchaseWeapon": { "$className": "RemoteEvent" },
        "SpitterSpit": { "$className": "RemoteEvent" },
        "GunFired": { "$className": "RemoteEvent" },
        "GunFiredEffect": { "$className": "RemoteEvent" },
        "CameraUpdate": { "$className": "UnreliableRemoteEvent" }
      }
    },

