      },
      "LobbyUI": {
        "$className": "ScreenGui",
        "$properties": { "ResetOnSpawn": false },
        "HUD": {
          "$className": "ScreenGui",
          "HUDController": { "$path": "src/gui/HUDController.client.luau" }
        },
        "OpenShop": { "$path": "src/gui/OpenShop.client.luau" },
        "LoadoutTabs": { "$path": "src/gui/LoadoutTabs.client.luau" },
