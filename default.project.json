{
  "name": "fps-game-test",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      },
      "Remotes": {
        "$className": "Folder",
        "DealDamage": { "$className": "RemoteEvent" },
        "FireProjectile": { "$className": "RemoteEvent" },
        "ProjectileSpawned": { "$className": "RemoteEvent" },
        "UseHealingPotion": { "$className": "RemoteEvent" }
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      }
    },

    "StarterPack": {
      "TestGun": {
        "$className": "Tool",
        "$properties": { "RequiresHandle": false },
        "GunScript": { "$path": "src/tools/TestGun/GunScript.client.luau" }
      },
      "Glock17": {
        "$className": "Tool",
        "GunScript": { "$path": "src/tools/Glock17/GunScript.client.luau" }
      },
      "M4": {
        "$className": "Tool",
        "GunScript": { "$path": "src/tools/M4/GunScript.client.luau" }
      },
      "Sniper": {
        "$className": "Tool",
        "GunScript": { "$path": "src/tools/Sniper/GunScript.client.luau" }
      },
      "TestGun2": {
        "$className": "Tool",
        "$properties": { "RequiresHandle": false },
        "GunScript": { "$path": "src/tools/TestGun2/GunScript.client.luau" }
      },
      "TestGun3": {
        "$className": "Tool",
        "$properties": { "RequiresHandle": false },
        "GunScript": { "$path": "src/tools/TestGun3/GunScript.client.luau" }
      },
      "HyperlaserGun": {
        "$className": "Tool",
        "$properties": { "RequiresHandle": false },
        "GunScript": { "$path": "src/tools/HyperlaserGun/GunScript.client.luau" }
      },
      "Shotgun": {
        "$className": "Tool",
        "$properties": { "RequiresHandle": false },
        "GunScript": { "$path": "src/tools/Shotgun/GunScript.client.luau" }
      },
      "Revolver": {
        "$className": "Tool",
        "$properties": { "RequiresHandle": false },
        "GunScript": { "$path": "src/tools/Revolver/GunScript.client.luau" }
      },
      "MP5": {
        "$className": "Tool",
        "$properties": { "RequiresHandle": false },
        "GunScript": { "$path": "src/tools/MP5/GunScript.client.luau" }
      },
      "HealingPotion": {
        "$className": "Tool",
        "$properties": { "RequiresHandle": false },
        "HealingPotionScript": { "$path": "src/tools/HealingPotion/HealingPotionScript.client.luau" }
      }
    },

    "StarterGui": {
      "LobbyUI": {
        "$className": "ScreenGui",
        "HUD": {
          "$className": "ScreenGui",
          "HUDController": { "$path": "src/gui/HUDController.client.luau" }
        },
        "OpenShop": { "$path": "src/gui/OpenShop.client.luau" },
        "LoadoutTabs": { "$path": "src/gui/LoadoutTabs.client.luau" },
        "WeaponListBuilder": { "$path": "src/gui/WeaponListBuilder.client.luau" }
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Color": [
            0.38823,
            0.37254,
            0.38823
          ],
          "Locked": true,
          "Position": [
            0,
            -10,
            0
          ],
          "Size": [
            512,
            20,
            512
          ]
        }
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}